generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model User {
  id            String         @id @default(cuid())
  name          String?
  email         String         @unique
  username      String?        @unique
  emailVerified Boolean        @default(false)
  image         String?
  signatureUrl  String?
  isApproved    Boolean        @default(false)
  role          String         @default("TEACHER") // ADMIN, TEACHER
  position      String? // ครู, หัวหน้าหมวด, ผู้อำนวยการ, แอดมิน
  subjectGroup  String?
  level         String?
  lineUserId    String?
  address       String?
  phoneNumber   String?
  createdAt     DateTime       @default(now())
  updatedAt     DateTime       @updatedAt
  sessions      Session[]
  accounts      Account[]
  leaveRequests LeaveRequest[]
}

model Session {
  id        String   @id @default(cuid())
  userId    String
  token     String   @unique
  expiresAt DateTime
  ipAddress String?
  userAgent String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model Account {
  id                    String    @id @default(cuid())
  userId                String
  accountId             String
  providerId            String
  accessToken           String?
  refreshToken          String?
  accessTokenExpiresAt  DateTime?
  refreshTokenExpiresAt DateTime?
  scope                 String?
  password              String?
  createdAt             DateTime  @default(now())
  updatedAt             DateTime  @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model LeaveRequest {
  id             String   @id @default(cuid())
  userId         String
  type           String // SICK, PERSONAL, VACATION
  startDate      DateTime
  endDate        DateTime
  reason         String
  status         String   @default("PENDING") // PENDING_HEAD, PENDING_EXEC, APPROVED, REJECTED
  documentUrl    String?
  headApproverId String?
  execApproverId String?
  rejectReason   String?
  extraFields    String?
  fiscalYear     Int?
  pendingSeq     Int?
  approvedSeq    Int?
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model SystemSettings {
  id                     String   @id @default("default")
  schoolName             String   @default("ชื่อโรงเรียน")
  affiliation            String   @default("สำนักงานเขตพื้นที่การศึกษามัธยมศึกษาอุดรธานี")
  subheader              String   @default("ระบบจัดการการลา")
  logoUrl                String?
  footerText             String   @default("© 2026 ระบบการลา")
  developerSecret        String   @default("admin1234") // Default secret
  lineChannelAccessToken String?
  lineTargetGroupId      String?
  leaveRules             String   @default("การลากิจต้องยื่นคำขอล่วงหน้าอย่างน้อย 3 วันทำการ\nการลาป่วยติดต่อกันเกิน 3 วัน ต้องแนบใบรับรองแพทย์\nระบบจะส่งแจ้งเตือนให้หัวหน้าหมวดของท่านพิจารณาเป็นลำดับแรก")
  requirePersonalAdvance Boolean  @default(true)
  memoThresholdTimes     Int      @default(6)
  memoThresholdDays      Int      @default(15)
  defaultInspectorId     String?
  actingDirectorTitle    String   @default("รักษาการในตำแหน่งผู้อำนวยการโรงเรียน")
  finalApproverUserIds   String   @default("") // Comma-separated user IDs allowed to give final approval (in addition to ผู้บริหาร)
  showActingDirectorTitle Boolean @default(true) // Toggle display of acting director title on printed forms
  updatedAt              DateTime @updatedAt
}

model LeaveConfig {
  id               String   @id @default(cuid())
  type             String   @unique
  name             String
  maxDaysPerYear   Int      @default(0)
  warningThreshold Int      @default(3) // เตือนเมื่อเหลือน้อยกว่านี้
  isActive         Boolean  @default(true)
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt
}

model SystemLog {
  id          String   @id @default(cuid())
  actionType  String // e.g., "CREATE_LEAVE", "APPROVE_LEAVE", "UPDATE_SETTINGS"
  description String
  userId      String
  createdAt   DateTime @default(now())
}

model LeaveArchive {
  id         String   @id @default(cuid())
  cycleLabel String // e.g., "รอบ 1/2569 (1 ต.ค. 68 - 31 มี.ค. 69)"
  cycleStart DateTime
  cycleEnd   DateTime
  data       String // JSON array of archived leave summaries
  totalStaff Int      @default(0)
  totalDays  Int      @default(0)
  archivedBy String // userId of admin who archived
  createdAt  DateTime @default(now())
}

model SystemBackup {
  id        String   @id @default(cuid())
  label     String // e.g., "Backup 19/05/2569"
  data      String // JSON of full system snapshot
  createdBy String // userId
  createdAt DateTime @default(now())
}
